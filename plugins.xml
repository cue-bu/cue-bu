<?xml version="1.0" encoding="UTF-8"?>
<plugins>

  <pyqgis_plugin name="layer2shp" version="3.10.3">

    <description><![CDATA[
表示しているレイヤを一括でshpとして出力します。
    ]]></description>

    <about><![CDATA[
レイヤパネルの全レイヤをShape形式でエクスポートします。
プラグインアイコンをクリックすると、レイヤ名をファイル名としたshpファイルが保存されます。
レイヤパネル内に複数同じ名前のレイヤが存在する場合は、レイヤパネル上で上から順に _数字 を末尾に付与します。
既に同じファイル名が存在する場合も、末尾の数字を連番にしてファイル名が作成されます。
ラスタレイヤや未形式のレイヤについては保存しません。
    ]]></about>

    <author_name>S.hiramatsu</author_name>
    <email>cue.bu2025@gmail.com</email>

    <homepage>https://cue.gozaru.jp/</homepage>
    <repository>https://cue-bu.github.io/cue-bu/plugins.xml</repository>
    <tracker></tracker>

    <tags>python,layer,shp,output</tags>

    <icon>https://cue-bu.github.io/cue-bu/icon/lyr2shp.png</icon>

    <version>3.10.3</version>
    <qgis_minimum_version>3.0</qgis_minimum_version>
    <qgis_maximum_version>3.99</qgis_maximum_version>

    <file_name>layer2shp.zip</file_name>
